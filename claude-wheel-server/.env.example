# Secret key for server access — set in the mobile app connection settings
# Minimum 20 characters, must include uppercase, lowercase, and digits
API_KEY=your_api_key_here

# Optional: Groq API key on the server side. If not set, the key from the mobile app is used.
# GROQ_API_KEY=your_groq_api_key_here

# File containing the list of sessions and their working directories
SESSIONS_LIST=sessions-list.txt

# Whisper model for speech recognition
WHISPER_MODEL=whisper-large-v3

# Default speech recognition language (ru, en, etc.; empty string = auto-detect)
STT_LANGUAGE=ru

# Port the server listens on
PORT=11000

# Maximum time to wait for Claude response, in seconds
ASK_TIMEOUT=240

# Session idle timeout in seconds — tmux session is stopped after this period of inactivity
IDLE_TIMEOUT=1800

# Save conversation history to .conversation.txt in the session working directory.
# discussion — only sessions whose path ends with /discussion
# all         — every session
# off         — disabled
CONVERSATION_LOG=discussion
